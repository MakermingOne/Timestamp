/* 顶部栏 */
.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 30rpx;
  background: #fff;
  border-bottom: 2rpx solid var(--border);
  position: sticky;
  top: 0;
  z-index: 100;
}

.brand-section {
  display: flex;
  flex-direction: column;
}

.brand {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--primary);
}

.tagline {
  font-size: 22rpx;
  color: var(--text-secondary);
  margin-top: 4rpx;
}

.header-actions {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.btn-upgrade {
  font-size: 24rpx;
  padding: 12rpx 24rpx;
  background: linear-gradient(135deg, var(--primary) 0%, var(--primary-light) 100%);
  color: #fff;
  border-radius: 100rpx;
  border: none;
}

/* 主内容区 */
.main-content {
  height: calc(100vh - 100rpx);
}

/* 区块标题 */
.section-title {
  display: flex;
  align-items: center;
  gap: 12rpx;
  font-size: 32rpx;
  font-weight: 600;
  margin-bottom: 24rpx;
  color: var(--text);
}

.section-title.pro {
  color: var(--warning);
}

.title-num {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 44rpx;
  height: 44rpx;
  background: var(--primary);
  color: #fff;
  border-radius: 50%;
  font-size: 24rpx;
  font-weight: 600;
}

.photo-count {
  font-size: 24rpx;
  color: var(--text-secondary);
  font-weight: normal;
  margin-left: auto;
}

/* 上传区域 */
.upload-section {
  margin-top: 24rpx;
}

.upload-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 60rpx 40rpx;
  border: 4rpx dashed var(--border);
  border-radius: 20rpx;
  background: #fafafa;
}

.upload-icon {
  font-size: 64rpx;
  margin-bottom: 16rpx;
}

.upload-text {
  font-size: 32rpx;
  color: var(--text);
  font-weight: 500;
  margin-bottom: 8rpx;
}

.upload-hint {
  font-size: 24rpx;
  color: var(--text-secondary);
}

/* 照片列表 */
.photo-list {
  margin-top: 24rpx;
  white-space: nowrap;
}

.photo-item {
  display: inline-block;
  position: relative;
  width: 160rpx;
  height: 160rpx;
  margin-right: 16rpx;
  border-radius: 16rpx;
  overflow: hidden;
  border: 4rpx solid transparent;
}

.photo-item.active {
  border-color: var(--primary);
}

.photo-thumb {
  width: 100%;
  height: 100%;
}

.photo-badge {
  position: absolute;
  top: 8rpx;
  left: 8rpx;
  width: 36rpx;
  height: 36rpx;
  background: var(--success);
  color: #fff;
  font-size: 20rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.photo-badge.no-exif {
  background: var(--warning);
}

.photo-remove {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 36rpx;
  height: 36rpx;
  background: rgba(0, 0, 0, 0.5);
  color: #fff;
  font-size: 28rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-clear {
  margin-top: 24rpx;
  font-size: 26rpx;
  color: var(--text-secondary);
  background: transparent;
  border: 2rpx solid var(--border);
  padding: 16rpx;
  border-radius: 12rpx;
}

/* 预览区域 */
.preview-section {
  padding-bottom: 20rpx;
}

.preview-container {
  position: relative;
  width: 100%;
  height: 500rpx;
  background: #f5f5f5;
  border-radius: 16rpx;
  overflow: hidden;
}

.preview-canvas {
  width: 100%;
  height: 100%;
}

.watermark-hint {
  position: absolute;
  bottom: 20rpx;
  left: 50%;
  transform: translateX(-50%);
  background: rgba(0, 0, 0, 0.6);
  color: #fff;
  padding: 12rpx 24rpx;
  border-radius: 100rpx;
  font-size: 24rpx;
}

.photo-info {
  margin-top: 20rpx;
  padding: 16rpx;
  background: #f9fafb;
  border-radius: 12rpx;
}

.photo-name {
  font-size: 28rpx;
  color: var(--text);
  font-weight: 500;
  display: block;
  margin-bottom: 8rpx;
}

.photo-meta {
  font-size: 24rpx;
  color: var(--text-secondary);
}

/* 设置项 */
.setting-item {
  margin-bottom: 32rpx;
}

.setting-item:last-child {
  margin-bottom: 0;
}

.setting-label {
  display: block;
  font-size: 28rpx;
  color: var(--text);
  margin-bottom: 16rpx;
  font-weight: 500;
}

.checkbox-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.checkbox-item .setting-label {
  margin-bottom: 0;
}

.picker-value {
  padding: 20rpx 24rpx;
  background: #f9fafb;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: var(--text);
}

/* 位置选择器 */
.position-grid {
  display: grid;
  grid-template-columns: repeat(3, 80rpx);
  grid-template-rows: repeat(3, 80rpx);
  gap: 12rpx;
  justify-content: center;
  width: 276rpx;
  margin: 0 auto;
}

.position-cell {
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f3f4f6;
  border-radius: 12rpx;
  border: 2rpx solid transparent;
}

.position-cell.active {
  background: var(--primary-soft);
  border-color: var(--primary);
}

.position-dot {
  width: 16rpx;
  height: 16rpx;
  background: var(--text-secondary);
  border-radius: 50%;
}

.position-cell.active .position-dot {
  background: var(--primary);
}

/* 滑块 */
slider {
  margin: 0;
}

/* 年龄预览 */
.age-preview {
  padding: 20rpx;
  background: linear-gradient(135deg, #fef3c7 0%, #fde68a 100%);
  border-radius: 12rpx;
  margin-top: 20rpx;
}

.age-preview text {
  font-size: 28rpx;
  color: #92400e;
  font-weight: 500;
}

/* 导出操作 */
.export-actions {
  display: flex;
  gap: 20rpx;
  margin: 24rpx;
  margin-top: 0;
}

.export-actions .btn {
  flex: 1;
}

/* 支持按钮 */
.support-btn {
  position: fixed;
  right: 30rpx;
  bottom: 40rpx;
  padding: 20rpx 32rpx;
  background: linear-gradient(135deg, #ec4899 0%, #f43f5e 100%);
  color: #fff;
  border-radius: 100rpx;
  font-size: 26rpx;
  font-weight: 500;
  box-shadow: 0 8rpx 20rpx rgba(236, 72, 153, 0.3);
  z-index: 90;
}

/* 弹窗 */
.modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.3s;
  z-index: 200;
}

.modal.show {
  opacity: 1;
  pointer-events: auto;
}

.modal-content {
  width: 80%;
  max-width: 600rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 40rpx;
  transform: scale(0.9);
  transition: transform 0.3s;
}

.modal.show .modal-content {
  transform: scale(1);
}

.modal-header {
  text-align: center;
  margin-bottom: 32rpx;
}

.modal-title {
  display: block;
  font-size: 36rpx;
  font-weight: 600;
  margin-bottom: 16rpx;
}

.price-tag {
  display: inline-block;
  font-size: 48rpx;
  font-weight: 700;
  padding: 12rpx 32rpx;
  border-radius: 100rpx;
  margin-bottom: 16rpx;
}

.price-pro {
  color: #dc2626;
  background: linear-gradient(135deg, #fef3c7 0%, #fee2e2 100%);
}

.price-free {
  color: #059669;
  background: linear-gradient(135deg, #d1fae5 0%, #a7f3d0 100%);
  font-size: 32rpx;
}

.modal-desc {
  font-size: 26rpx;
  color: var(--text-secondary);
}

.pro-features {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
  margin-bottom: 32rpx;
}

.feature-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 24rpx;
  color: var(--text);
}

.feature-check {
  color: var(--success);
  font-weight: 700;
}

.payment-methods {
  display: flex;
  justify-content: center;
  gap: 40rpx;
  margin-bottom: 32rpx;
}

.payment-method {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.payment-qr {
  width: 200rpx;
  height: 260rpx;
  border: 2rpx solid var(--border);
  border-radius: 12rpx;
  background: #f9fafb;
}

.payment-method text {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.modal-actions {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

/* Toast */
.toast {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  background: rgba(0, 0, 0, 0.8);
  color: #fff;
  padding: 24rpx 48rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.3s;
  z-index: 300;
}

.toast.show {
  opacity: 1;
}

/* 输入框样式 */
input {
  padding: 20rpx 24rpx;
  background: #f9fafb;
  border-radius: 12rpx;
  font-size: 28rpx;
  border: 2rpx solid var(--border);
}
